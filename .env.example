# winbit32MCP example configuration — copy to .env (or export in your unit
# file) and fill in what you use. Every capability degrades gracefully:
# unset groups just don't register their tools/endpoints.

# ── Server ───────────────────────────────────────────────────────────
GATEWAY_REST_PORT=8820
GATEWAY_MCP_PORT=8821
GATEWAY_REST_HOST=127.0.0.1
GATEWAY_SERVICE_NAME=winbit32
# MCP tool-name prefix: winbit32_q, winbit32_make_payment, …
GATEWAY_TOOL_PREFIX=winbit32
#GATEWAY_WEBHOOK_SIGNATURE_HEADER=X-Winbit32-Signature

# ── x402 (accept USDC per call, Base) ────────────────────────────────
#X402_RECIPIENT_ADDRESS=0x...
#X402_NETWORK=base
#X402_FACILITATOR_URL=
#X402_CDP_API_KEY_ID=
#X402_CDP_API_KEY_SECRET=

# ── NFPT scanner (view-key watches + Zcash scan backend) ─────────────
#NFPT_BASE_URL=https://api.zcash.winbit32.com
#NFPT_API_KEY=

# ── Private watch store ──────────────────────────────────────────────
#PRIVATE_WATCH_DB=./private-watch.db
# 32-byte hex; REQUIRED to create watches:
#PRIVATE_WATCH_ENCRYPTION_KEY=

# ── Privacy-chain RPC (Penny Oracle `q` facts) ───────────────────────
#MONERO_RPC_URL=http://127.0.0.1:18081
#ZCASH_RPC_URL=http://127.0.0.1:8232

# ── XMR/ZEC top-ups (operator view-only receive wallets) ─────────────
#XMR_RECV_ADDRESS=
#XMR_RECV_VIEW_KEY=
#ZEC_RECV_ADDRESS=
#ZEC_RECV_UFVK=

# ── Make payments (co-signed shielded ZEC) ───────────────────────────
# The gateway's FROST share; make_payment tools only register when set.
#MAKE_PAYMENT_WULT_PATH=/etc/winbit32/vault-share.wult
#MAKE_PAYMENT_WULT_PASSWORD=
# Directory holding orchard_frost_wasm.js + orchard_frost_wasm_bg.wasm:
#MAKE_PAYMENT_WASM_DIR=/etc/winbit32/orchard-frost
#MAKE_PAYMENT_RELAY_URL=https://cosign.winbit32.com
#MAKE_PAYMENT_PCZT_API_BASE=
#MAKE_PAYMENT_SCANNER_BASE=
#MAKE_PAYMENT_BIRTHDAY_HEIGHT=
#MAKE_PAYMENT_MAX_ZEC=0.1
#MAKE_PAYMENT_MAX_PENDING=3
# Standalone cosigner page for clickable deep links (qrPayload goes in the
# URL hash). Default: https://winbit32.com/cosign.html
#COSIGN_APP_URL=https://winbit32.com/cosign.html
