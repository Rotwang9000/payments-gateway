# winbit32MCP example configuration — copy to .env (or export in your unit
# file) and fill in what you use. Every capability degrades gracefully:
# unset groups just don't register their tools/endpoints.

# ── Server ───────────────────────────────────────────────────────────
GATEWAY_REST_PORT=8820
GATEWAY_MCP_PORT=8821
GATEWAY_REST_HOST=127.0.0.1
GATEWAY_SERVICE_NAME=winbit32
# MCP tool-name prefix: winbit32_q, winbit32_make_payment, …
GATEWAY_TOOL_PREFIX=winbit32
#GATEWAY_WEBHOOK_SIGNATURE_HEADER=X-Winbit32-Signature

# ── x402 (accept USDC per call, Base) ────────────────────────────────
#X402_RECIPIENT_ADDRESS=0x...
#X402_NETWORK=base
#X402_FACILITATOR_URL=
#X402_CDP_API_KEY_ID=
#X402_CDP_API_KEY_SECRET=

# ── Hosted AI (prepaid credit bundles + OpenAI-compatible proxy) ─────
# Enabled when AI_UPSTREAM_API_KEY is set. The upstream key never reaches the
# browser: buyers pay one x402 USDC bundle at POST /v1/ai/credits for a short-
# lived session token, then spend it at POST /v1/ai/chat/completions (the proxy
# meters tokens + debits the bundle). Requires X402_RECIPIENT_ADDRESS above.
#AI_UPSTREAM_BASE_URL=https://openrouter.ai/api/v1
#AI_UPSTREAM_API_KEY=
#AI_DEFAULT_MODEL=openai/gpt-4o-mini
#AI_UPSTREAM_REFERER=
#AI_UPSTREAM_TITLE=
#AI_MODEL_ALLOWLIST=
#AI_PUBLIC_BASE_URL=
#AI_DB=
#AI_SESSION_TTL_SEC=2592000
#AI_CREDIT_DEFAULT_USD_CENTS=500
#AI_CREDIT_MIN_USD_CENTS=50
#AI_CREDIT_MAX_USD_CENTS=2000
#AI_PRICE_PER_1K_INPUT_ATOMIC=1000
#AI_PRICE_PER_1K_OUTPUT_ATOMIC=3000
#AI_MIN_CALL_ATOMIC=200

# ── NFPT scanner (view-key watches + Zcash scan backend) ─────────────
#NFPT_BASE_URL=https://api.zcash.winbit32.com
#NFPT_API_KEY=

# ── Private watch store ──────────────────────────────────────────────
#PRIVATE_WATCH_DB=./private-watch.db
# 32-byte hex; REQUIRED to create watches:
#PRIVATE_WATCH_ENCRYPTION_KEY=

# ── Privacy-chain RPC (Penny Oracle `q` facts) ───────────────────────
#MONERO_RPC_URL=http://127.0.0.1:18081
#ZCASH_RPC_URL=http://127.0.0.1:8232

# ── XMR/ZEC top-ups (operator view-only receive wallets) ─────────────
#XMR_RECV_ADDRESS=
#XMR_RECV_VIEW_KEY=
#ZEC_RECV_ADDRESS=
#ZEC_RECV_UFVK=

# ── Make payments (co-signed shielded ZEC) ───────────────────────────
# The gateway's FROST share; make_payment tools only register when set.
#MAKE_PAYMENT_WULT_PATH=/etc/winbit32/vault-share.wult
#MAKE_PAYMENT_WULT_PASSWORD=
# Directory holding orchard_frost_wasm.js + orchard_frost_wasm_bg.wasm:
#MAKE_PAYMENT_WASM_DIR=/etc/winbit32/orchard-frost
#MAKE_PAYMENT_RELAY_URL=https://cosign.winbit32.com
#MAKE_PAYMENT_PCZT_API_BASE=
#MAKE_PAYMENT_SCANNER_BASE=
#MAKE_PAYMENT_BIRTHDAY_HEIGHT=
#MAKE_PAYMENT_MAX_ZEC=0.1
#MAKE_PAYMENT_MAX_PENDING=3
# Standalone cosigner page for clickable deep links (qrPayload goes in the
# URL hash). Default: https://winbit32.com/cosign.html
#COSIGN_APP_URL=https://winbit32.com/cosign.html

# ── x402 payer relay (spend a prepaid balance at ANY x402 endpoint) ──
# DORMANT / EXPERIMENTAL — intentionally kept OFF. This custodial relay
# (we hold the balance AND transmit it to third parties) is money-
# transmission-shaped; the non-custodial successor (the user's own
# Vultisig vault swaps + signs the payment) is planned in winbit32. Leave
# these UNSET in production. They only TUNE the relay IF a host ever wires
# a funded payer (opts.x402Payer = a Base signer + x402 client); the
# standalone gateway never builds a payer itself. Caps are atomic USDC
# (1_000_000 = $1); the global daily cap is the float guard; fee = greater
# of a flat floor or %.
#RELAY_MAX_PER_CALL_ATOMIC=1000000
#RELAY_MAX_PER_DAY_PER_ACCOUNT_ATOMIC=10000000
#RELAY_MAX_PER_DAY_GLOBAL_ATOMIC=25000000
#RELAY_FEE_FLAT_ATOMIC=1000
#RELAY_FEE_BPS=500
#RELAY_NETWORK=eip155:8453
#RELAY_USDC_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#RELAY_PER_IP_PER_MIN=30
#RELAY_ALLOW_HTTP=0
